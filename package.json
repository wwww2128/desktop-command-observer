{
  "name": "desktop-command-observer",
  "version": "0.1.0",
  "description": "Windows desktop state observer that emits snapshot and patch JSON for faster computer-use agents.",
  "license": "MIT",
  "type": "module",
  "private": true,
  "bin": {
    "desktop-agent": "./bin/desktop-agent.ts"
  },
  "scripts": {
    "snapshot": "node ./bin/desktop-agent.ts snapshot",
    "watch": "node ./bin/desktop-agent.ts watch",
    "capture:computer-use": "node ./scripts/capture-computer-use-windows.ts",
    "bridge:computer-use": "node ./scripts/computer-use-bridge.ts",
    "test": "node --test"
  },
  "engines": {
    "node": ">=24"
  }
}
