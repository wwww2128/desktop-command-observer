{
  "name": "computer-use-observer-layer",
  "version": "0.1.0",
  "description": "Unofficial observer layer that streams Windows desktop context for OpenAI Computer Use agents.",
  "license": "MIT",
  "type": "module",
  "private": true,
  "bin": {
    "cu-observer": "./bin/cu-observer.ts"
  },
  "scripts": {
    "snapshot": "node ./bin/cu-observer.ts snapshot",
    "watch": "node ./bin/cu-observer.ts watch",
    "capture:computer-use": "node ./scripts/capture-computer-use-windows.ts",
    "bridge:computer-use": "node ./scripts/computer-use-bridge.ts",
    "context:agent": "node ./scripts/agent-context.ts",
    "context:watch": "node ./scripts/agent-context.ts --watch",
    "context:live": "node ./scripts/live-agent-context.ts",
    "test": "node --test"
  },
  "engines": {
    "node": ">=24"
  }
}
